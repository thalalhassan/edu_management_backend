{
  "info": {
    "_postman_id": "your-collection-id",
    "name": "Auth API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"your-email@example.com\",\n  \"password\": \"your-password\"\n}",
          "options": {
            "raw": "json"
          }
        },
        "url": {
          "raw": "{{baseUrl}}/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Refresh Token",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refresh_token\": \"your-refresh-token\"\n}",
          "options": {
            "raw": "json"
          }
        },
        "url": {
          "raw": "{{baseUrl}}/refresh",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "refresh"
          ]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api/v1/auth",
      "type": "string",
      "description": "Base URL for the API"
    }
  ]
}
